{
  "name": "promptlens",
  "displayName": "PromptLens",
  "description": "AI-assisted coding with semantic fingerprint provenance.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "PromptLens",
      "properties": {
        "promptlens.apiKey": {
          "type": "string",
          "default": "",
          "description": "Please enter your API Key (sk-...)"
        },
        "promptlens.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com/chat/completions",
          "description": "Please enter the API endpoint URL"
        },
        "promptlens.model": {
          "type": "string",
          "default": "deepseek-coder",
          "description": "Please enter the model name"
        }
      }
    },
    "commands": [
      {
        "command": "promptlens.insertPromptMark",
        "title": "PromptLens: Insert Prompt Mark"
      },
      {
        "command": "promptlens.cancelGeneration",
        "title": "PromptLens: Cancel Generation"
      },
      {
        "command": "promptlens.test",
        "title": "PromptLens: Test"
      }
    ],
    "keybindings": [
      {
        "command": "promptlens.insertPromptMark",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.52.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}